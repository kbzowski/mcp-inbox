# --- Required IMAP credentials --------------------------------------------
IMAP_USER=you@example.com
IMAP_PASSWORD=your-app-password-here
IMAP_HOST=imap.example.com

# --- IMAP connection (optional; defaults shown) ---------------------------
IMAP_PORT=993
IMAP_TLS=true
IMAP_TLS_REJECT_UNAUTHORIZED=true
IMAP_AUTH_TIMEOUT_MS=10000

# --- SMTP (optional; falls back to IMAP credentials) ----------------------
# SMTP_HOST defaults to IMAP_HOST when unset.
# SMTP_USER / SMTP_PASSWORD default to IMAP_USER / IMAP_PASSWORD.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=

# --- Cache layer ----------------------------------------------------------
# Enable the local SQLite cache (default true). Disable for stateless mode.
IMAP_CACHE_ENABLED=true

# Cache directory. Defaults to the platform user-cache dir:
#   - Linux/macOS: $XDG_CACHE_HOME/mcp-inbox or ~/.cache/mcp-inbox
#   - Windows:     %LOCALAPPDATA%\mcp-inbox\Cache
IMAP_CACHE_DIR=

# Maximum total size of the on-disk attachment cache (MB). LRU eviction.
IMAP_CACHE_MAX_ATTACHMENTS_MB=500

# Eagerly cache plain-text and HTML bodies on first sync (false = fetch on demand).
IMAP_CACHE_BODY_INLINE=false

# Default freshness window for read tools (seconds). Can be overridden per call
# via each tool's `max_staleness_seconds` argument.
IMAP_CACHE_DEFAULT_STALENESS_SEC=60

# How long to retain cached emails per folder (days). 0 = forever.
IMAP_CACHE_RETAIN_DAYS=365

# --- IDLE (server-push) ---------------------------------------------------
# Comma-separated folder names to keep under IDLE for real-time cache updates.
# Empty string = no IDLE connections (cache still works, just not push-fresh).
IMAP_IDLE_FOLDERS=INBOX

# --- Debug ----------------------------------------------------------------
# Comma-separated debug namespaces, e.g. "mcp-inbox:*" or "mcp-inbox:cache".
# Output goes to stderr only (stdin/stdout are reserved for the MCP transport).
DEBUG=
